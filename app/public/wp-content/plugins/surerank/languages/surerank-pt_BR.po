msgstr "Vindo do Yoast, Rank Math ou AIOSEO? Importe todos os seus títulos, descrições e configurações existentes para o SureRank com um clique."

#: build/admin-dashboard/index.js:1
msgid "Start Migration"
msgstr "Iniciar Migração"

#: build/admin-dashboard/index.js:1
msgid "Help Google Find You"
msgstr "Ajude o Google a Encontrá-lo"

#: build/admin-dashboard/index.js:1
msgid "Make sure search engines can discover, crawl, and index all your content."
msgstr "Certifique-se de que os mecanismos de busca possam descobrir, rastrear e indexar todo o seu conteúdo."

#: build/admin-dashboard/index.js:1
msgid "Configure and enable your XML sitemap"
msgstr "Configure e ative seu sitemap XML"

#: build/admin-dashboard/index.js:1
msgid "Choose which post types and pages to include, then submit your sitemap to Google Search Console so every page gets discovered."
msgstr "Escolha quais tipos de postagens e páginas incluir, e depois envie seu sitemap para o Google Search Console para que cada página seja descoberta."

