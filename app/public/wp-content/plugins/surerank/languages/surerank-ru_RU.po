msgstr "%1$d из %2$d шагов настройки завершено. Еще несколько, и ваш сайт будет готов."

#: build/admin-dashboard/index.js:1
msgid "Continue"
msgstr "Продолжить"

#: build/admin-dashboard/index.js:1
msgid "Auto-detected"
msgstr "Автоопределено"

#: build/admin-dashboard/index.js:1
#, js-format
msgid "Learn more about %s"
msgstr "Узнайте больше о %s"

#: build/admin-dashboard/index.js:1
#, js-format
msgid "Chapter progress: %d%%"
msgstr "Прогресс главы: %d%%"

#: build/admin-dashboard/index.js:1
msgid "You're all set!"
msgstr "Вы все настроили!"

#: build/admin-dashboard/index.js:1
msgid "You’ve completed every recommended setup step. Visit the docs or reach out if you’d like to go deeper."
msgstr "Вы завершили все рекомендуемые шаги настройки. Посетите документацию или свяжитесь с нами, если хотите углубиться."

#: build/admin-dashboard/index.js:1
msgid "Open Docs"
msgstr "Открыть документацию"

#: build/admin-dashboard/index.js:1
msgid "Contact Support"
msgstr "Связаться с поддержкой"

#: build/admin-dashboard/index.js:1
msgid "Set up SureRank end to end with a step-by-step guide to make your site discoverable, shareable, and ready to rank."
msgstr "Настройте SureRank от начала до конца с пошаговым руководством, чтобы сделать ваш сайт доступным, удобным для обмена и готовым к ранжированию."
