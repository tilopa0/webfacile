msgstr "Откройте вкладку \"Дополнительно\" в метабоксе SureRank"

#: inc/analyzer/seo-analyzer.php:759
msgid "Enter the correct URL in the Canonical Tag field"
msgstr "Введите правильный URL в поле канонического тега"

