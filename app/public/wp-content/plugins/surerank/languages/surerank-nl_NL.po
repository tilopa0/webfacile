msgstr "SureRank Pro helpt u uw startpagina te optimaliseren voor sociale delen met AI-gestuurde suggesties en voorbeelden."

#: inc/analyzer/seo-analyzer.php:1190
msgid "Structured Data Found on the Homepage"
msgstr "Gestructureerde gegevens gevonden op de homepage"

#: inc/analyzer/seo-analyzer.php:1191
msgid "The homepage currently includes structured data (schema)."
msgstr "De homepage bevat momenteel gestructureerde gegevens (schema)."

#: inc/analyzer/seo-analyzer.php:1193
