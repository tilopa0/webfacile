#: build/admin-dashboard/index.js:1
msgid "Run SureRank's site-wide health check to see everything rated Poor or Satisfactory, then fix the issues that are holding your site back."
msgstr "Voer SureRank's site-brede gezondheidscontrole uit om alles te zien dat als Slecht of Voldoende is beoordeeld, en los vervolgens de problemen op die je site tegenhouden."

#: build/admin-dashboard/index.js:1
msgid "View SEO Analysis"
msgstr "Bekijk SEO-analyse"

#: build/admin-dashboard/index.js:1
msgid "Optimize Your Pages"
msgstr "Optimaliseer je pagina's"

#: build/admin-dashboard/index.js:1
msgid "Use the SureRank metabox to make every post and page work harder in search results."
msgstr "Gebruik de SureRank metabox om elk bericht en elke pagina harder te laten werken in zoekresultaten."

#: build/admin-dashboard/index.js:1
msgid "Set title & meta description for a page"
msgstr "Stel titel en meta-beschrijving voor een pagina in"

#: build/admin-dashboard/index.js:1
msgid "Open the SureRank metabox right from the posts or pages listing, or from inside the editor, to write a custom SEO title and meta description and preview exactly how it'll look in Google before publishing."
msgstr "Open de SureRank metabox direct vanuit de lijst met berichten of pagina's, of vanuit de editor, om een aangepaste SEO-titel en meta-beschrijving te schrijven en precies te zien hoe het eruit zal zien in Google voordat je publiceert."

#: build/admin-dashboard/index.js:1
msgid "View Pages"
msgstr "Bekijk pagina's"

#: build/admin-dashboard/index.js:1
msgid "Run your page-level SEO check"
msgstr "Voer je SEO-controle op paginaniveau uit"

#: build/admin-dashboard/index.js:1
msgid "See a real-time checklist of on-page SEO factors like keyword usage, heading structure, internal links, and image alt text, and fix what’s flagged."
msgstr "Bekijk een realtime checklist van on-page SEO-factoren zoals het gebruik van zoekwoorden, de structuur van koppen, interne links en alt-tekst van afbeeldingen, en los op wat gemarkeerd is."

#: build/admin-dashboard/index.js:1
msgid "Open Page Analysis"
msgstr "Open pagina-analyse"

#: build/admin-dashboard/index.js:1
msgid "Add schema markup to your content"
msgstr "Voeg schema-markup toe aan je inhoud"

#: build/admin-dashboard/index.js:1
msgid "Pick the right schema type for each page (Article, FAQ, HowTo, Product) to help Google understand your content and unlock rich results in search."
msgstr "Kies het juiste schema-type voor elke pagina (Artikel, FAQ, HowTo, Product) om Google te helpen je inhoud te begrijpen en rijke resultaten in zoekopdrachten te ontgrendelen."

#: build/admin-dashboard/index.js:1
msgid "Optimize your images with alt text"
msgstr "Optimaliseer je afbeeldingen met alt-tekst"

#: build/admin-dashboard/index.js:1
msgid "SureRank automatically generates alt text for your images, improving how search engines understand your content and making your site more accessible."
msgstr "SureRank genereert automatisch alt-tekst voor je afbeeldingen, waardoor zoekmachines je inhoud beter begrijpen en je site toegankelijker wordt."

#: build/admin-dashboard/index.js:1
msgid "Configure Image SEO"
msgstr "Configureer afbeeldings-SEO"

#: build/admin-dashboard/index.js:1
msgid "Social Appearance"
msgstr "Sociale weergave"

#: build/admin-dashboard/index.js:1
msgid "Control exactly how your content looks when shared on Facebook, LinkedIn, and X."
msgstr "Beheer precies hoe je inhoud eruitziet wanneer deze wordt gedeeld op Facebook, LinkedIn en X."

#: build/admin-dashboard/index.js:1
msgid "Set your fallback Open Graph image"
msgstr "Stel je fallback Open Graph-afbeelding in"

#: build/admin-dashboard/index.js:1
msgid "Choose the default image that appears whenever any page on your site is shared on social. Used when a page has no featured image of its own."
msgstr "Kies de standaardafbeelding die verschijnt wanneer een pagina op je site op sociale media wordt gedeeld. Gebruikt wanneer een pagina geen eigen uitgelichte afbeelding heeft."

#: build/admin-dashboard/index.js:1
msgid "Configure OG Image"
msgstr "Configureer OG-afbeelding"

#: build/admin-dashboard/index.js:1
msgid "Add your Facebook profile links"
msgstr "Voeg je Facebook-profiel links toe"

#: build/admin-dashboard/index.js:1
msgid "Enter your site's and author's Facebook page URLs. SureRank adds them to your structured data so search engines link your brand to its verified social profile."
msgstr "Voer de URL's van de Facebook-pagina's van je site en auteur in. SureRank voegt ze toe aan je gestructureerde gegevens, zodat zoekmachines je merk koppelen aan zijn geverifieerde sociale profiel."

#: build/admin-dashboard/index.js:1
msgid "Configure Facebook"
msgstr "Configureer Facebook"

#: build/admin-dashboard/index.js:1
msgid "Set up X (Twitter) cards"
msgstr "Stel X (Twitter) kaarten in"

#: build/admin-dashboard/index.js:1
msgid "Add your X username and choose your card type so your content displays as a rich image preview, not just a plain link, when shared on X."
msgstr "Voeg je X-gebruikersnaam toe en kies je kaarttype, zodat je inhoud wordt weergegeven als een rijke afbeeldingspreview, niet alleen als een gewone link, wanneer deze op X wordt gedeeld."

#: build/admin-dashboard/index.js:1
msgid "Configure X Cards"
msgstr "Configureer X-kaarten"

#: build/admin-dashboard/index.js:1
msgid "Override social settings for a specific page"
msgstr "Overschrijf sociale instellingen voor een specifieke pagina"

#: build/admin-dashboard/index.js:1
msgid "Open the SureRank metabox right from the posts or pages listing, or from inside the editor, then use the Social tab to set a different image, title, or description for that page when it’s shared."
msgstr "Open de SureRank-metabox direct vanuit de lijst met berichten of pagina's, of vanuit de editor, en gebruik het tabblad Sociaal om een andere afbeelding, titel of beschrijving in te stellen voor die pagina wanneer deze wordt gedeeld."

#: build/admin-dashboard/index.js:1
msgid "Could not update Learn progress."
msgstr "Kon de voortgang van Leren niet bijwerken."

#: build/admin-dashboard/index.js:1
msgid "Continue Learning"
msgstr "Ga door met leren"

#: build/admin-dashboard/index.js:1
#, js-format
msgid "%1$d of %2$d setup steps complete. A few more and your site is ready."
msgstr "%1$d van %2$d installatie stappen voltooid. Nog een paar en je site is klaar."

#: build/admin-dashboard/index.js:1
msgid "Continue"
msgstr "Ga door"

#: build/admin-dashboard/index.js:1
msgid "Auto-detected"
msgstr "Automatisch gedetecteerd"

#: build/admin-dashboard/index.js:1
#, js-format
msgid "Learn more about %s"
msgstr "Leer meer over %s"

#: build/admin-dashboard/index.js:1
#, js-format
msgid "Chapter progress: %d%%"
msgstr "Hoofdstuk voortgang: %d%%"

#: build/admin-dashboard/index.js:1
msgid "You're all set!"
msgstr "Je bent helemaal klaar!"

#: build/admin-dashboard/index.js:1
msgid "You’ve completed every recommended setup step. Visit the docs or reach out if you’d like to go deeper."
msgstr "Je hebt elke aanbevolen installatie stap voltooid. Bezoek de documentatie of neem contact op als je dieper wilt gaan."

#: build/admin-dashboard/index.js:1
msgid "Open Docs"
msgstr "Open documentatie"

#: build/admin-dashboard/index.js:1
msgid "Contact Support"
msgstr "Neem contact op met ondersteuning"

#: build/admin-dashboard/index.js:1
msgid "Set up SureRank end to end with a step-by-step guide to make your site discoverable, shareable, and ready to rank."
msgstr "Stel SureRank van begin tot eind in met een stapsgewijze handleiding om je site ontdekbaar, deelbaar en klaar om te ranken te maken."
