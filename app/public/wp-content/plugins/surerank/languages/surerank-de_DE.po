msgid "Continue"
msgstr "Fortfahren"

#: build/admin-dashboard/index.js:1
msgid "Auto-detected"
msgstr "Automatisch erkannt"

#: build/admin-dashboard/index.js:1
#, js-format
msgid "Learn more about %s"
msgstr "Erfahren Sie mehr über %s"

#: build/admin-dashboard/index.js:1
#, js-format
